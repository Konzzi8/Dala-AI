# --- App URL (production: your real domain; used for Microsoft OAuth redirect) ---
# NEXT_PUBLIC_APP_URL=https://app.yourcompany.com
# NEXTAUTH_URL=https://app.yourcompany.com

# --- Supabase (required) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional server fallbacks
# SUPABASE_URL=
# SUPABASE_ANON_KEY=

# Service role: local demo/bootstrap only — never expose to the browser
# SUPABASE_SERVICE_ROLE_KEY=

# --- AI (optional but recommended for production quality) ---
# Chat + drafts + ingest extraction (preferred). Ingest falls back to OpenAI if unset.
ANTHROPIC_API_KEY=
# Optional override (default: claude-sonnet-4-20250514)
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional: ingest extraction fallback if Anthropic is not set
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# Optional proxy / Azure OpenAI
# OPENAI_BASE_URL=

# --- Microsoft 365 / Outlook (optional) ---
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# MICROSOFT_TENANT_ID=common

# --- Cron: Outlook sync (Authorization: Bearer <secret>) ---
# CRON_SECRET=

# --- Demo / dev only — leave unset in production ---
# ENABLE_DEMO_AUTH=false
# NEXT_PUBLIC_ENABLE_DEMO_BOOTSTRAP=false
# DEMO_LOGIN_EMAIL=
# DEMO_LOGIN_PASSWORD=

# --- Advanced: split API origin (usually leave unset) ---
# NEXT_PUBLIC_API_BASE_URL=
