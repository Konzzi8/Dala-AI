# Supabase (browser + server)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: legacy names (server-only scripts)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Required for Outlook sync cron (server only — never expose)
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (Copilot + email drafts)
ANTHROPIC_API_KEY=

# Microsoft Graph / Outlook OAuth
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=

# App URL for OAuth redirect and cookies
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: email parsing still uses OpenAI if set
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Cron (Vercel sends Authorization: Bearer …)
CRON_SECRET=
